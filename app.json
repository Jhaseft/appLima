{
  "expo": {
    "name": "TransferCash",
    "slug": "Lima",
    "scheme": "transfercash",
    "version": "4.7",
    "orientation": "portrait",
    "icon": "./assets/logopro.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logopro.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.transfercash.lima",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.transfercash.lima",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/logopro.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      "expo-web-browser",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.269848220574-u1nncraprer9mf731ibf7j77dsjp2r47"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c896182e-bb15-4c0e-96ca-1037184c0576"
      }
    }
  }
}
